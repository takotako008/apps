  "html": "<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>WeBrew - Compact View</title>\n    <style>\n        body, html {\n            margin: 0;\n            padding: 0;\n            height: 100%;\n            background-color: #f0f0f0; /* 背景をグレーにして枠をわかりやすく */\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .container {\n            /* ここでサイズを調整（幅375px, 高さ667pxは一般的なスマホサイズ） */\n            width: 375px;\n            height: 80vh; \n            max-width: 95%;\n            background: #fff;\n            box-shadow: 0 10px 25px rgba(0,0,0,0.2);\n            border-radius: 10px;\n            overflow: hidden;\n            position: relative;\n        }\n\n        iframe {\n            width: 100%;\n            height: 100%;\n            border: none;\n        }\n    </style>\n</head>\n<body>\n\n    <div class=\"container\">\n        <iframe src=\"https://lollonote.vercel.app/webrew.html\"></iframe>\n    </div>\n\n</body>\n</html>"
