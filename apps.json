    "bg": "linear-gradient(135deg, #01875f, #1ce39d)",
    "html": "<div style='background:#f1f3f4;height:100%;display:flex;flex-direction:column;font-family:sans-serif;color:#333;'><div style='background:#fff;padding:20px;font-size:18px;font-weight:bold;color:#01875f;border-bottom:1px solid #ddd;display:flex;align-items:center;'><span style='margin-right:10px;'>◀</span>Apps Developers</div><div style='padding:15px;flex:1;overflow-y:auto;'><div style='background:#fff;border-radius:12px;padding:15px;box-shadow:0 2px 5px rgba(0,0,0,0.1);margin-bottom:15px;'><div style='margin-bottom:15px;'><label style='font-size:12px;color:#666;display:block;margin-bottom:5px;'>App Name</label><input id='dn' style='width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;box-sizing:border-box;' placeholder='Counter'></div><div style='margin-bottom:15px;'><label style='font-size:12px;color:#666;display:block;margin-bottom:5px;'>Icon (Select Emoji)</label><div id='emoji-picker' style='display:grid;grid-template-columns:repeat(6,1fr);gap:5px;background:#f9f9f9;padding:10px;border-radius:8px;border:1px solid #eee;max-height:100px;overflow-y:auto;'></div><input type='hidden' id='di' value='📱'></div><div style='margin-bottom:10px;'><label style='font-size:12px;color:#666;display:block;margin-bottom:5px;'>Background Color</label><div style='display:flex;align-items:center;gap:10px;'><input type='color' id='db' style='width:50px;height:50px;border:none;background:none;cursor:pointer;' value='#34c759'><span id='color-hex' style='font-family:monospace;font-size:14px;'>#34c759</span></div></div></div><div style='background:#fff;border-radius:12px;padding:15px;box-shadow:0 2px 5px rgba(0,0,0,0.1);'><label style='font-size:12px;color:#666;display:block;margin-bottom:5px;'>HTML Code</label><textarea id='dh' style='width:100%;height:120px;border:1px solid #ddd;border-radius:8px;padding:10px;box-sizing:border-box;font-family:monospace;' placeholder='<h2>Title</h2>...'></textarea></div><button onclick='window.sendApp()' style='width:100%;background:#01875f;color:#fff;border:none;padding:15px;border-radius:30px;font-weight:bold;margin-top:20px;box-shadow:0 4px 10px rgba(1,135,95,0.3);'>Discordへ送信</button><p id='st' style='text-align:center;font-size:12px;margin-top:10px;color:#666;'></p></div><script>const emojis=['❤️','🍎','🚗','🔥','🧡','🍊','🦊','🏀','💛','🍋','🌟','🐱','💚','🍏','🌲','🥦','💙','🧊','🐳','💧','💜','🍇','👾','🔮','🖤','🎱','📓','🕶️','🤍','☁️','🏐','✉️'];const picker=document.getElementById('emoji-picker');const di=document.getElementById('di');emojis.forEach(e=>{const s=document.createElement('span');s.innerText=e;s.style.cssText='font-size:24px;cursor:pointer;text-align:center;padding:5px;border-radius:5px;';s.onclick=()=>{document.querySelectorAll(\"#emoji-picker span\").forEach(x=>x.style.background=\"transparent\");s.style.background=\"#e0e0e0\";di.value=e;};picker.appendChild(s)});const db=document.getElementById('db');db.oninput=()=>{document.getElementById('color-hex').innerText=db.value.toUpperCase();};window.sendApp=async()=>{const u='https://discord.com/api/webhooks/1476917815859740786/4Oqp9s_to-ZQhMsLhUDjmeZIMqQCArxbkEMRVwxkbfgZUY2T-sTjIkWvAFuZ4aMGVnHU';const n=document.getElementById('dn').value,i=di.value,b=db.value,h=document.getElementById('dh').value,s=document.getElementById('st');if(!n||!h)return alert('Missing data');const eh=h.replace(/\\r?\\n|\\r/g,'').replace(/\"/g,'\\\\\"').replace(/\\//g,'\\\\/');const p={content:`🆕 **App Submission**\\n\\`\\`\\`json\\n{\\n  \"name\": \"${n}\",\\n  \"icon\": \"${i}\",\\n  \"bg\": \"${b}\",\\n  \"html\": \"${eh}\"\\n}\\n\\`\\`\\``};s.innerText='Sending...';try{const r=await fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)});if(r.ok)s.innerText='✅ Sent to Discord!';else throw new Error();}catch(e){s.innerText='❌ Failed to send.';}}</script></div>"
  }
