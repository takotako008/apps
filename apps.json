  {
    "name": "Developers",
    "icon": "🛠️",
    "bg": "linear-gradient(135deg, #01875f, #1ce39d)",
    "html": "<div style='background:#f1f3f4;height:100%;display:flex;flex-direction:column;font-family:sans-serif;color:#333;'><div style='background:#fff;padding:20px;font-size:18px;font-weight:bold;color:#01875f;border-bottom:1px solid #ddd;display:flex;align-items:center;'><span style='margin-right:10px;'>◀</span>Apps Developers</div><div style='padding:15px;flex:1;overflow-y:auto;'><div style='background:#fff;border-radius:12px;padding:15px;box-shadow:0 2px 5px rgba(0,0,0,0.1);margin-bottom:15px;'><div style='margin-bottom:15px;'><label style='font-size:12px;color:#666;display:block;margin-bottom:5px;'>App Name</label><input id='dn' style='width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;box-sizing:border-box;' placeholder='Counter'></div><div style='margin-bottom:15px;'><label style='font-size:12px;color:#666;display:block;margin-bottom:5px;'>Icon (Emoji Picker)</label><div id='emoji-list' style='display:grid;grid-template-columns:repeat(6,1fr);gap:5px;background:#f9f9f9;padding:10px;border-radius:8px;border:1px solid #eee;max-height:100px;overflow-y:auto;font-size:24px;'></div><input type='hidden' id='di' value='📱'></div><div style='margin-bottom:10px;'><label style='font-size:12px;color:#666;display:block;margin-bottom:5px;'>Background (Color Palette)</label><div style='display:flex;align-items:center;gap:15px;'><input type='color' id='db' style='width:60px;height:40px;border:none;background:none;cursor:pointer;' value='#34c759'><b id='hex-val' style='font-family:monospace;'>#34C759</b></div></div></div><div style='background:#fff;border-radius:12px;padding:15px;box-shadow:0 2px 5px rgba(0,0,0,0.1);'><label style='font-size:12px;color:#666;display:block;margin-bottom:5px;'>HTML Code (File upload mode)</label><textarea id='dh' style='width:100%;height:150px;border:1px solid #ddd;border-radius:8px;padding:10px;box-sizing:border-box;font-family:monospace;' placeholder='ここに長いコードを貼ってください'></textarea></div><button onclick='window.sendAppFile()' style='width:100%;background:#01875f;color:#fff;border:none;padding:15px;border-radius:30px;font-weight:bold;margin-top:20px;box-shadow:0 4px 10px rgba(1,135,95,0.3);'>Discordへファイル送信</button><p id='st' style='text-align:center;font-size:12px;margin-top:10px;color:#666;'></p></div><script>const emojis=['❤️','🍎','🚗','🔥','🧡','🍊','🦊','🏀','💛','🍋','🌟','🐱','💚','🍏','🌲','🥦','💙','🧊','🐳','💧','💜','🍇','👾','🔮','🖤','🎱','📓','🕶️','🤍','☁️','🏐','✉️'];const list=document.getElementById('emoji-list');emojis.forEach(e=>{const s=document.createElement('span');s.innerText=e;s.style.cursor='pointer';s.onclick=()=>{document.querySelectorAll(\"#emoji-list span\").forEach(x=>x.style.background=\"transparent\");s.style.background=\"#ddd\";s.style.borderRadius=\"5px\";document.getElementById('di').value=e;};list.appendChild(s)});const cp=document.getElementById('db');cp.oninput=()=>{document.getElementById('hex-val').innerText=cp.value.toUpperCase();};window.sendAppFile=async()=>{const url='https://discord.com/api/webhooks/1476917815859740786/4Oqp9s_to-ZQhMsLhUDjmeZIMqQCArxbkEMRVwxkbfgZUY2T-sTjIkWvAFuZ4aMGVnHU';const n=document.getElementById('dn').value,i=document.getElementById('di').value,b=cp.value,h=document.getElementById('dh').value,s=document.getElementById('st');if(!n||!h){alert('入力が足りません');return;}s.innerText='ファイルを生成中...';const jsonStr=JSON.stringify({name:n,icon:i,bg:b,html:h},null,2);const blob=new Blob([jsonStr],{type:'application/json'});const formData=new FormData();formData.append('file',blob,'app_submission.json');formData.append('payload_json',JSON.stringify({content:`🆕 **新アプリ申請 (ファイル形式)**\\nアプリ名: **${n}**`}));try{const res=await fetch(url,{method:'POST',body:formData});if(res.ok)s.innerText='✅ ファイル送信完了！';else s.innerText='❌ 送信失敗';}catch(e){s.innerText='❌ エラーが発生しました';}}</script></div>"
  }
]
