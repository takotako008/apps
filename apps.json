IMqQCArxbkEMRVwxkbfgZUY2T-sTjIkWvAFuZ4aMGVnHU';const n=document.getElementById('dn').value,i=document.getElementById('di').value,b=document.getElementById('db').value,h=document.getElementById('dh').value,s=document.getElementById('st');if(!n||!h)return alert('Missing data');const eh=h.replace(/\\r?\\n|\\r/g,'').replace(/\"/g,'\\\\\"').replace(/\\//g,'\\\\/');const p={content:`🆕 **App Submission**\\n\\`\\`\\`json\\n{\\n  \"name\": \"${n}\",\\n  \"icon\": \"${i||'📱'}\",\\n  \"bg\": \"${b||'#fff'}\",\\n  \"html\": \"${eh}\"\\n}\\n\\`\\`\\``};s.innerText='Sending...';try{const r=await fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)});if(r.ok)s.innerText='✅ Sent to Discord!';else throw new Error();}catch(e){s.innerText='❌ Failed to send.';}}</script></div>"
